{
  "name": "loop-gym",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && vercel --prod --yes",
    "build:native": "cross-env BUILD_TARGET=native vite build",
    "sync:android": "npm run build:native && npx cap sync android",
    "sync:ios": "npm run build:native && npx cap sync ios",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.108.2",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "vite": "^5.4.11",
    "wouter": "^3.10.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "typescript": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
